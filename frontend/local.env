# =============================================================================
# ALPHA5 SCHEDULER FRONTEND - LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================

# =============================================================================
# API CONFIGURATION
# =============================================================================
REACT_APP_API_URL=http://localhost:8001
REACT_APP_WS_URL=ws://localhost:8001/ws
REACT_APP_API_TIMEOUT=30000
REACT_APP_API_RETRY_ATTEMPTS=3
REACT_APP_API_RETRY_DELAY=1000

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development
REACT_APP_BUILD_DATE=2024-01-01
REACT_APP_COMMIT_HASH=dev

# =============================================================================
# FEATURE FLAGS
# =============================================================================
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_DEBUG=true
REACT_APP_ENABLE_HOT_RELOAD=true
REACT_APP_ENABLE_DEV_TOOLS=true
REACT_APP_ENABLE_PERFORMANCE_MONITORING=true

# =============================================================================
# UI CONFIGURATION
# =============================================================================
REACT_APP_THEME=hedge_fund_dark
REACT_APP_DEFAULT_LANGUAGE=en
REACT_APP_TIMEZONE=America/New_York
REACT_APP_DATE_FORMAT=MMM dd, yyyy
REACT_APP_TIME_FORMAT=HH:mm:ss
REACT_APP_CURRENCY=USD

# =============================================================================
# AUTHENTICATION CONFIGURATION
# =============================================================================
REACT_APP_AUTH_ENABLED=true
REACT_APP_AUTH_TOKEN_KEY=auth_token
REACT_APP_AUTH_REFRESH_TOKEN_KEY=refresh_token
REACT_APP_AUTH_TOKEN_EXPIRE_MINUTES=30
REACT_APP_AUTH_REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# REAL-TIME CONFIGURATION
# =============================================================================
REACT_APP_WS_ENABLED=true
REACT_APP_WS_RECONNECT_INTERVAL=5000
REACT_APP_WS_MAX_RECONNECT_ATTEMPTS=5
REACT_APP_WS_HEARTBEAT_INTERVAL=30000

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
REACT_APP_MONITORING_ENABLED=true
REACT_APP_MONITORING_SAMPLE_RATE=0.1
REACT_APP_MONITORING_ENDPOINT=http://localhost:8001/metrics
REACT_APP_MONITORING_SERVICE_NAME=alpha5-scheduler

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
REACT_APP_DEBUG_MODE=true
REACT_APP_LOG_LEVEL=debug
REACT_APP_CONSOLE_LOGGING=true
REACT_APP_NETWORK_LOGGING=true
REACT_APP_PERFORMANCE_LOGGING=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Alpaca API Configuration
REACT_APP_ALPACA_API_KEY=
REACT_APP_ALPACA_API_SECRET=
REACT_APP_ALPACA_API_URL=https://paper-api.alpaca.markets
REACT_APP_ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/sip

# Market Data Configuration
REACT_APP_MARKET_DATA_ENABLED=true
REACT_APP_MARKET_DATA_REALTIME=true
REACT_APP_MARKET_DATA_CACHE_TTL=300

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
REACT_APP_NOTIFICATIONS_ENABLED=true
REACT_APP_NOTIFICATION_POSITION=top-right
REACT_APP_NOTIFICATION_DURATION=5000
REACT_APP_NOTIFICATION_MAX_VISIBLE=5

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
REACT_APP_CACHE_ENABLED=true
REACT_APP_CACHE_TTL=300000
REACT_APP_CACHE_MAX_SIZE=50
REACT_APP_CACHE_STORAGE=localStorage

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
REACT_APP_LAZY_LOADING=true
REACT_APP_CODE_SPLITTING=true
REACT_APP_MEMOIZATION=true
REACT_APP_VIRTUALIZATION=true
REACT_APP_DEBOUNCE_DELAY=300

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
REACT_APP_SECURITY_HEADERS=true
REACT_APP_CSP_ENABLED=true
REACT_APP_XSS_PROTECTION=true
REACT_APP_HTTPS_ONLY=false

# =============================================================================
# LOCALIZATION CONFIGURATION
# =============================================================================
REACT_APP_DEFAULT_LOCALE=en
REACT_APP_SUPPORTED_LOCALES=en,es,fr,de
REACT_APP_FALLBACK_LOCALE=en

# =============================================================================
# THEME CONFIGURATION
# =============================================================================
REACT_APP_PRIMARY_COLOR=#00D4AA
REACT_APP_SECONDARY_COLOR=#6C5CE7
REACT_APP_SUCCESS_COLOR=#00B894
REACT_APP_ERROR_COLOR=#E17055
REACT_APP_WARNING_COLOR=#FDCB6E
REACT_APP_INFO_COLOR=#74B9FF

# =============================================================================
# DEVELOPMENT SERVER CONFIGURATION
# =============================================================================
REACT_APP_DEV_SERVER_HOST=0.0.0.0
REACT_APP_DEV_SERVER_PORT=3001
REACT_APP_DEV_SERVER_HTTPS=false
REACT_APP_DEV_SERVER_OPEN=true

# =============================================================================
# BUILD CONFIGURATION
# =============================================================================
REACT_APP_BUILD_TARGET=development
REACT_APP_SOURCE_MAP=true
REACT_APP_MINIFY=false
REACT_APP_OPTIMIZE=false

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
REACT_APP_TEST_MODE=false
REACT_APP_TEST_API_URL=http://localhost:8001
REACT_APP_TEST_WS_URL=ws://localhost:8001/ws
REACT_APP_TEST_TIMEOUT=10000

# =============================================================================
# ANALYTICS CONFIGURATION
# =============================================================================
REACT_APP_ANALYTICS_ENABLED=true
REACT_APP_ANALYTICS_TRACKING_ID=GA-XXXXXXXXX
REACT_APP_ANALYTICS_DEBUG=false
REACT_APP_ANALYTICS_SAMPLE_RATE=1.0

# =============================================================================
# ERROR REPORTING CONFIGURATION
# =============================================================================
REACT_APP_ERROR_REPORTING_ENABLED=true
REACT_APP_ERROR_REPORTING_DSN=https://your-sentry-dsn@sentry.io/project
REACT_APP_ERROR_REPORTING_ENVIRONMENT=development
REACT_APP_ERROR_REPORTING_SAMPLE_RATE=1.0

# =============================================================================
# HOT RELOAD CONFIGURATION
# =============================================================================
REACT_APP_HOT_RELOAD=true
REACT_APP_HOT_RELOAD_PORT=3000
REACT_APP_HOT_RELOAD_HOST=localhost
REACT_APP_HOT_RELOAD_PROTOCOL=ws

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
REACT_APP_OVERRIDE_PRODUCTION=false
REACT_APP_USE_MOCK_DATA=false
REACT_APP_DISABLE_AUTHENTICATION=false
REACT_APP_ENABLE_DEBUG_PANEL=true
REACT_APP_SHOW_DEV_TOOLS=true
