# =============================================================================
# ALPHA5 SCHEDULER - LOCAL DEVELOPMENT ENVIRONMENT
# =============================================================================

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://markets:changeme@localhost:5432/markets_prod
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=markets_prod
POSTGRES_USER=markets
POSTGRES_PASSWORD=changeme
POSTGRES_SCHEMA=public

# Database Connection Pool Settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=2
REDIS_PASSWORD=
REDIS_SSL=False
REDIS_TIMEOUT=5
REDIS_MAX_CONNECTIONS=20

# =============================================================================
# SCHEDULER CONFIGURATION
# =============================================================================
SCHEDULER_TIMEZONE=America/New_York
MAX_CONCURRENT_TASKS=100
TASK_TIMEOUT=300
SCHEDULER_POOL_SIZE=10
SCHEDULER_MAX_WORKERS=20

# Job Store Configuration
JOB_STORE_URL=sqlite:///jobs.sqlite
JOB_STORE_TABLE=apscheduler_jobs
JOB_STORE_ECHO=False

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8001
API_WORKERS=1
API_RELOAD=True
API_LOG_LEVEL=info

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=True
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=*

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-please-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production-please-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# API Key Configuration
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=your-api-key-for-development

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_FILE=logs/scheduler.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# Structured Logging
LOG_STRUCTURED=True
LOG_JSON_FORMAT=True

# =============================================================================
# TASK EXECUTION CONFIGURATION
# =============================================================================
DEFAULT_TIMEOUT=30
DEFAULT_MAX_RETRIES=3
DEFAULT_RETRY_DELAY=60
DEFAULT_CONCURRENT_EXECUTIONS=1

# HTTP Client Configuration
HTTP_TIMEOUT=30
HTTP_MAX_RETRIES=3
HTTP_RETRY_DELAY=1
HTTP_POOL_CONNECTIONS=10
HTTP_POOL_MAXSIZE=20

# =============================================================================
# MONITORING & HEALTH CHECKS
# =============================================================================
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_RETRIES=3

# Metrics Configuration
METRICS_ENABLED=True
METRICS_PORT=9090
METRICS_PATH=/metrics

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
REACT_APP_API_URL=http://localhost:8001
REACT_APP_WS_URL=ws://localhost:8001/ws
REACT_APP_VERSION=1.0.0
REACT_APP_ENVIRONMENT=development

# Frontend Build Configuration
REACT_APP_ENABLE_ANALYTICS=True
REACT_APP_ENABLE_NOTIFICATIONS=True
REACT_APP_ENABLE_DEBUG=True
REACT_APP_ENABLE_HOT_RELOAD=True

# =============================================================================
# DEVELOPMENT TOOLS
# =============================================================================
DEBUG=True
DEVELOPMENT=True
TESTING=False
PROFILING=False

# Hot Reload Configuration
HOT_RELOAD=True
HOT_RELOAD_INTERVAL=1
HOT_RELOAD_DEBOUNCE=1000

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Alpaca API Configuration
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_API_URL=https://paper-api.alpaca.markets
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# Market Data Configuration
MARKET_DATA_ENABLED=True
MARKET_DATA_REALTIME=True
MARKET_DATA_CACHE_TTL=300

# =============================================================================
# NOTIFICATION CONFIGURATION
# =============================================================================
NOTIFICATIONS_ENABLED=True
NOTIFICATION_EMAIL_ENABLED=False
NOTIFICATION_SLACK_ENABLED=False
NOTIFICATION_WEBHOOK_ENABLED=True

# Email Configuration (if enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=True

# Slack Configuration (if enabled)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#scheduler-alerts

# =============================================================================
# CACHING CONFIGURATION
# =============================================================================
CACHE_ENABLED=True
CACHE_TTL=300
CACHE_MAX_SIZE=1000
CACHE_BACKEND=redis

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================
WORKER_PROCESSES=1
WORKER_THREADS=4
WORKER_CONNECTIONS=1000

# Memory Configuration
MAX_MEMORY_USAGE=512MB
MEMORY_CLEANUP_INTERVAL=300

# =============================================================================
# DEVELOPMENT DATABASE
# =============================================================================
# SQLite for local development (alternative to PostgreSQL)
SQLITE_DATABASE_URL=sqlite:///./scheduler.db
SQLITE_ECHO=False

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
TEST_DATABASE_URL=sqlite:///./test_scheduler.db
TEST_REDIS_URL=redis://localhost:6379/15
TEST_TIMEOUT=30

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================
DOCKER_HOST=localhost
DOCKER_PORT=2375
DOCKER_TLS_VERIFY=False
DOCKER_CERT_PATH=

# =============================================================================
# ENVIRONMENT SPECIFIC
# =============================================================================
ENVIRONMENT=development
NODE_ENV=development
PYTHON_ENV=development

# Timezone Configuration
TZ=America/New_York
UTC_OFFSET=-5

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_BULK_OPERATIONS=True
FEATURE_TASK_TEMPLATES=True
FEATURE_ADVANCED_SCHEDULING=True
FEATURE_REAL_TIME_MONITORING=True
FEATURE_EXECUTION_HISTORY=True
FEATURE_PERFORMANCE_ANALYTICS=True
FEATURE_ALERT_SYSTEM=True
FEATURE_API_DOCUMENTATION=True

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
SECURITY_HEADERS=True
SECURITY_CORS=True
SECURITY_CSRF=False
SECURITY_RATE_LIMITING=True
SECURITY_RATE_LIMIT=100
SECURITY_RATE_WINDOW=60

# Input Validation
VALIDATION_STRICT=True
VALIDATION_MAX_LENGTH=10000
VALIDATION_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,HEAD,OPTIONS

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
BACKUP_ENABLED=True
BACKUP_INTERVAL=3600
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=./backups

# =============================================================================
# DEVELOPMENT UTILITIES
# =============================================================================
# Database Migration
ALEMBIC_CONFIG=alembic.ini
MIGRATION_PATH=./migrations

# Code Quality
LINTING_ENABLED=True
FORMATTING_ENABLED=True
TYPE_CHECKING=True

# Testing
TESTING_ENABLED=True
COVERAGE_ENABLED=True
COVERAGE_THRESHOLD=80

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Application Performance Monitoring
APM_ENABLED=False
APM_SERVICE_NAME=alpha5-scheduler
APM_SERVICE_VERSION=1.0.0

# Distributed Tracing
TRACING_ENABLED=False
TRACING_SERVICE_NAME=alpha5-scheduler
TRACING_SAMPLING_RATE=0.1

# =============================================================================
# DEVELOPMENT SERVER CONFIGURATION
# =============================================================================
# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
BACKEND_DEBUG=True
BACKEND_RELOAD=True

# Frontend Server
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=3000
FRONTEND_DEBUG=True
FRONTEND_HOT_RELOAD=True

# =============================================================================
# LOCAL DEVELOPMENT OVERRIDES
# =============================================================================
# Override production settings for local development
OVERRIDE_PRODUCTION_SETTINGS=True
USE_LOCAL_DATABASE=True
USE_LOCAL_REDIS=True
DISABLE_SSL=True
DISABLE_AUTHENTICATION=False
ENABLE_DEBUG_ENDPOINTS=True
